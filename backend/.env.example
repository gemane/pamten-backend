ARCADEDB_URL=http://<your-instance>:2480
ARCADEDB_USERNAME=root
ARCADEDB_PASSWORD=<password>
ARCADEDB_DATABASE=pamten

# Must be a long random string in production — the app refuses to start
# with the insecure default when DEBUG=False.
SECRET_KEY=<long-random-string>

# Comma-separated list of allowed frontend origins for CORS (no wildcard
# is used since requests are authenticated with credentials).
CORS_ORIGINS=https://pamten-frontend.onrender.com,http://localhost:5173

DEBUG=True

# Master scraper switch — must be true for any scraper to run
SCRAPER_ENABLED=false

# Individual scraper switches (master switch must also be true)
SCRAPER_WIKIDATA_ENABLED=false
SCRAPER_SEC_EDGAR_ENABLED=false
SCRAPER_OPENCORPORATES_ENABLED=false
# BODS dataset imports (large files – run manually)
SCRAPER_BODS_GLEIF_ENABLED=false    # ~1.1 GB download, ~5 M entities
SCRAPER_BODS_UK_PSC_ENABLED=false   # ~3.3 GB download, ~8 M entities

# Optional API keys (leave empty to use free tier)
OPENCORPORATES_API_KEY=

# Directory that BODS import endpoints may read local_file from
BODS_DATA_DIR=/data

# Geocoding (Nominatim / OpenStreetMap). Turn on to geocode addresses to
# coordinates. Set a contact email — the public Nominatim endpoint's usage
# policy requires a descriptive User-Agent, and enforces ~1 request/second.
GEOCODING_ENABLED=false
GEOCODING_CONTACT=
# NOMINATIM_URL=https://nominatim.openstreetmap.org/search
# GEOCODING_MIN_INTERVAL=1.0
